# App
NODE_ENV=development
PORT=3000
API_PREFIX=/api

# MongoDB
MONGODB_URI=mongodb://mongo:27017/doc-generator
MONGODB_DB_NAME=doc-generator

# Redis
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Bull Queue
QUEUE_CONCURRENCY=10
QUEUE_NAME=document-generation

# PDF Generation
PDF_TIMEOUT_MS=5000
PDF_WORKER_POOL_SIZE=4

# Rate Limiting
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX_REQUESTS=100

# Circuit Breaker
CIRCUIT_BREAKER_TIMEOUT=3000
CIRCUIT_BREAKER_ERROR_THRESHOLD=50
CIRCUIT_BREAKER_RESET_TIMEOUT=30000

# Logs
LOG_LEVEL=info

# Secrets
JWT_SECRET=change_me_in_production